{
  "realm": "arvel",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "admin", "description": "Arvel admin panel access" }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@arvel.test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Arvel",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin"]
    }
  ],
  "clients": [
    {
      "clientId": "arvel-admin",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:8000/*"],
      "webOrigins": ["+"],
      "protocolMappers": [
        {
          "name": "arvel-admin-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "arvel-admin",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}
