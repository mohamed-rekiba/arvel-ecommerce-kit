# Copy to `.env` (`cp .env.example .env`). These defaults match docker-compose.yml, so after
# `docker compose up -d` (or `make up`) the app runs with no edits. Override per environment.

APP_NAME="Arvel Shop"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
# run `arvel key:generate` (or `make setup`) to fill this
APP_KEY=
FRONTEND_URL=http://localhost:5173    # the storefront+admin SPA (`make front`) — used for CORS + links

# --- Database (PostgreSQL) ----------------------------------------------------
DATABASE_URL=postgresql+asyncpg://arvel:arvel@localhost:5432/arvel_ecommerce_kit

# --- Cache + Queue (Valkey — Redis-protocol, so URLs stay redis://) -----------
SESSION_DRIVER=redis          # cookie (in-process) | redis — backed by the same Valkey below
CACHE_STORE=redis              # array (in-process) | redis
CACHE_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0    # the raw redis facade (config/redis.py) — K9 broadcasting's driver
QUEUE_CONNECTION=amqp          # memory | redis | amqp — AMQP (RabbitMQ) is the kit default so the
                               # queued mail/notification rail runs on a real broker; redis (Valkey
                               # on :6379/1) works identically
QUEUE_URL=amqp://guest:guest@localhost:5672/
BROADCAST_CONNECTION=redis     # log (records, no network) | redis — order/stock live-update events

# --- Filesystem ---------------------------------------------------------------
FILESYSTEM_DISK=s3          # local | s3 (RustFS). Flip to s3 + create the bucket to use RustFS.
AWS_ACCESS_KEY_ID=arvel
AWS_SECRET_ACCESS_KEY=arvelsecret
AWS_BUCKET=arvel
AWS_ENDPOINT=http://localhost:9000   # RustFS S3 API (path-style)

# --- Search (Meilisearch on :7700) --------------------------------------------
SEARCH_DRIVER=meilisearch       # array (in-process) | meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=arvel-dev-master-key

# --- Mail (Mailpit — catches all mail; web UI http://localhost:8025) ----------
MAIL_MAILER=smtp               # log | smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=shop@arvel.test
MAIL_FROM_NAME="Arvel Shop"

# --- Admin OIDC (Keycloak on :8080) -------------------------------------------
# The `arvel` realm + `arvel-admin` client + an `admin` user (admin/admin) auto-import on first boot
# (docker/keycloak/realm-export.json). Keycloak master console admin is admin/admin.
OIDC_ISSUER=http://localhost:8080/realms/arvel
OIDC_AUDIENCE=arvel-admin
OIDC_ADMIN_ROLE=admin

# --- Payment gateway (the kit uses a fake gateway in tests) -------------------
PAYMENT_GATEWAY_URL=http://localhost:8000/api/dev-gateway  # the built-in dev PSP stub (debug only); point at a real gateway in prod
PAYMENT_GATEWAY_SECRET=test-secret

# --- Telemetry (off by default; point at an OTLP collector to enable) ---------
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# --- AI (arvel-ai gateway + MCP) ----------------------------------------------
# The AI product-copy feature talks to any OpenAI-compatible endpoint (a LiteLLM proxy,
# vLLM, Ollama's OpenAI route, …). There's no gateway in docker-compose, so point
# AI_GATEWAY_URL + AI_API_KEY at your own to make real calls — without them the copy
# endpoint has no model to reach (the test suite uses AI.fake(), so it needs neither).
# (Comments sit above the blank vars on purpose: an inline # after an empty value is
# read as the value.)
AI_DRIVER=openai_compatible    # openai_compatible | litellm | fake
# e.g. http://localhost:4000 (a local LiteLLM proxy) — required for real calls
AI_GATEWAY_URL=
# bearer token for that gateway (read from env, never written into config)
AI_API_KEY=
AI_MODEL_FAST=claude-haiku-4-5    # the "fast" model alias (config/ai.py)
AI_MODEL_SMART=claude-opus-4-8    # the "smart" model alias
# bearer token clients present to the MCP server at /mcp
MCP_TOKEN=
