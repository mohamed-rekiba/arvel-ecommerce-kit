# Copy to `.env` (`cp .env.example .env`). These defaults match docker-compose.yml, so after
# `docker compose up -d` the app runs with no edits. Override per environment.

APP_NAME="Arvel Shop"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_KEY=base64:local-dev-key-change-me-please-0000000000

# --- Database (PostgreSQL — see docker-compose.yml) ---------------------------
DATABASE_URL=postgresql+asyncpg://arvel:arvel@localhost:5432/arvel_ecommerce_kit

# --- Sessions / cache / queue / filesystem ------------------------------------
SESSION_DRIVER=cookie
CACHE_STORE=array            # array (in-process) | redis
QUEUE_CONNECTION=memory      # memory | redis | amqp
FILESYSTEM_DISK=local        # local | s3 (RustFS/MinIO/AWS via the s3.* vars)

# --- Admin OIDC (Keycloak) — admins sign in via the IdP -----------------------
OIDC_ISSUER=http://localhost:8080/realms/arvel
OIDC_AUDIENCE=arvel-admin
OIDC_ADMIN_ROLE=admin

# --- Payment gateway (the kit uses a fake gateway in tests) -------------------
PAYMENT_GATEWAY_URL=https://payments.example.test
PAYMENT_GATEWAY_SECRET=test-secret

# --- Telemetry (off by default; point at an OTLP collector to enable) ---------
OTEL_ENABLED=false
