# Copy to `.env` (`cp .env.example .env`). These defaults match docker-compose.yml, so after
# `docker compose up -d` (or `make up`) the app runs with no edits. Override per environment.

APP_NAME="Arvel Shop"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_KEY=                       # run `arvel key:generate` (or `make setup`) to fill this

# --- Database (PostgreSQL) ----------------------------------------------------
DATABASE_URL=postgresql+asyncpg://arvel:arvel@localhost:5432/arvel_ecommerce_kit

# --- Cache + Queue (Valkey — Redis-protocol, so URLs stay redis://) -----------
SESSION_DRIVER=cookie
CACHE_STORE=redis              # array (in-process) | redis
CACHE_URL=redis://localhost:6379/0
QUEUE_CONNECTION=redis         # memory | redis | amqp (RabbitMQ on :5672, guest/guest)
QUEUE_URL=redis://localhost:6379/1

# --- Filesystem ---------------------------------------------------------------
FILESYSTEM_DISK=local          # local | s3 (RustFS). Flip to s3 + create the bucket to use RustFS.
AWS_ACCESS_KEY_ID=arvel
AWS_SECRET_ACCESS_KEY=arvelsecret
AWS_BUCKET=arvel
AWS_ENDPOINT=http://localhost:9000   # RustFS S3 API (path-style)

# --- Mail (Mailpit — catches all mail; web UI http://localhost:8025) ----------
MAIL_MAILER=smtp               # log | smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=shop@arvel.test
MAIL_FROM_NAME="Arvel Shop"

# --- Admin OIDC (Keycloak on :8080) -------------------------------------------
# The `arvel` realm + `arvel-admin` client + an `admin` user (admin/admin) auto-import on first boot
# (docker/keycloak/realm-export.json). Keycloak master console admin is admin/admin.
OIDC_ISSUER=http://localhost:8080/realms/arvel
OIDC_AUDIENCE=arvel-admin
OIDC_ADMIN_ROLE=admin

# --- Payment gateway (the kit uses a fake gateway in tests) -------------------
PAYMENT_GATEWAY_URL=https://payments.example.test
PAYMENT_GATEWAY_SECRET=test-secret

# --- Telemetry (off by default; point at an OTLP collector to enable) ---------
OTEL_ENABLED=false
