__pycache__/
*.py[cod]
.venv/
.env
.env.*
!.env.example
*.sqlite
*.db
/bootstrap/cache/*.py
.pytest_cache/
.ruff_cache/
.vite/
node_modules/
dist/
.aios/
.repowise/
frontend/test-results/
frontend/playwright-report/

# populated at Docker build time from frontend/dist/ (bootstrap/app.py's with_public_dir(...),
# arvel's static front door) — source of truth is frontend/public/ + the
# Vite build, not this directory
/public/

# storage/ holds runtime-written files (uploads today; file-based cache/session/log backends if
# arvel ever implements them) — only the placeholder .gitignore files are tracked, everything else
# under here (including any future subdirectory) is not.
storage/*
!storage/app/
storage/app/*
!storage/app/.gitignore
!storage/app/public/
storage/app/public/*
!storage/app/public/.gitignore
